  \                            PAYLOAD_LONG_STRING_CHARACTER.repeat(LONG_STRING_LENGTH),\r\
  \n                            false,\r\n                            Category.BOUNDARY\r\
  \n                    ));\r\n                }\r\n            }\r\n\r\n        \
  \    if (TEST_INJECTION) {\r\n                if (TEST_SQLI) {\r\n             \
  \       specs.add(new MutationSpec(\r\n                            \"STRING_SQLI\"\
  ,\r\n                            \"SQL Injection payload\",\r\n                \
